{
  "defaultShell": "/bin/bash",
  "allowedDirectories": [
    "/root",
    "/home/user",
    "/tmp"
  ],
  "blockedCommands": [
    "rm -rf /",
    "rm -rf /*",
    "rm -rf ~",
    "rm -rf --no-preserve-root /",
    "mkfs",
    "mkfs.ext4",
    "mkfs.xfs",
    "mkfs.btrfs",
    "dd",
    "fdisk",
    "parted",
    "sgdisk",
    "wipefs",
    "shred",
    "blkdiscard",
    "mount",
    "umount",
    "shutdown",
    "reboot",
    "poweroff",
    "halt",
    "init",
    "systemctl poweroff",
    "systemctl reboot",
    "chown -R / ",
    "chmod -R 000 /",
    "chmod -R 777 /",
    ":(){ :|:& };:",
    "sudo passwd",
    "passwd root",
    "userdel",
    "deluser",
    "iptables -F",
    "ufw disable",
    "> /dev/sda"
  ],
  "fileReadLineLimit": 1000,
  "fileWriteLineLimit": 200,
  "telemetryEnabled": false
}
