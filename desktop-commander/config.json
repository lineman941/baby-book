{
  "defaultShell": "/bin/bash",
  "allowedDirectories": [
    "/root",
    "/workspace",
    "/tmp"
  ],
  "blockedCommands": [
    "rm",
    "mkfs",
    "dd",
    "fdisk",
    "parted",
    "sgdisk",
    "wipefs",
    "shred",
    "blkdiscard",
    "mount",
    "umount",
    "shutdown",
    "reboot",
    "poweroff",
    "halt",
    "init",
    "systemctl",
    "chown",
    "chmod",
    "passwd",
    "userdel",
    "deluser",
    "iptables",
    "ufw",
    "sudo"
  ],
  "fileReadLineLimit": 1000,
  "fileWriteLineLimit": 200,
  "telemetryEnabled": false
}
